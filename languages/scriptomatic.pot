msgstr ""

#: dist/scriptomatic/includes/trait-pages.php:837
#: includes/trait-pages.php:839
msgid "Dual Nonce Verification:"
msgstr ""

#: dist/scriptomatic/includes/trait-pages.php:837
#: includes/trait-pages.php:839
msgid "Each form carries both the WordPress Settings API nonce and a secondary location-specific nonce, verified on every save."
msgstr ""

#: dist/scriptomatic/includes/trait-pages.php:838
#: includes/trait-pages.php:840
msgid "Rate Limiting:"
msgstr ""

#: dist/scriptomatic/includes/trait-pages.php:838
#: includes/trait-pages.php:840
